# ============================================================
# AI Expense Tracker - Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local
# ============================================================

# MongoDB Atlas connection string
# Get from: Atlas -> Cluster -> Connect -> Drivers -> Node.js
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# JWT signing secret - generate a random 32+ char string
# Quick generator: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# AI provider - Groq (OpenAI-compatible API, generous free tier)
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
# Optional model override. Default: llama-3.3-70b-versatile
# Other options: llama-3.1-8b-instant (faster, cheaper), llama-3.1-70b-versatile
GROQ_MODEL=

# Public app URL (used for absolute links if needed)
# Local: http://localhost:3000
# Prod:  https://<your-vercel-app>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
